{
    "name": "extenbox/notify",
    "description": "Multi Provider SMS Package For PHP & Laravel",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Extenbox\\Notify\\": "src/"
        }
    },
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "illuminate/support": "Required for Laravel service provider and Laravel facade support."
    },
    "extra": {
        "laravel": {
            "providers": [
                "Extenbox\\Notify\\NotifyServiceProvider"
            ],
            "aliases": {
                "Notify": "Extenbox\\Notify\\Laravel\\NotifyFacade"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
